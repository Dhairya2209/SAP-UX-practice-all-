<mvc:View 
    controllerName="demo.demoprac.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page title="Search bar filter">
        <content>
            <VBox class="sapUiSmallMargin">

                <SearchField 
                    width="100%"
                    liveChange="onSearch"
                    placeholder="Search by name or city"/>

                <Table 
                    id="idTable"
                    items="{/employees}">

                    <columns>
                        <Column><Text text="ID"/></Column>
                        <Column><Text text="Name"/></Column>
                        <Column><Text text="City"/></Column>
                    </columns>

                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{id}"/>
                                <Text text="{name}"/>
                                <Text text="{city}"/>
                            </cells>
                        </ColumnListItem>
                    </items>

                </Table>

            </VBox>
        </content>
    </Page>

</mvc:View>