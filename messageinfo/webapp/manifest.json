{
  "_version": "1.83.0",
  "sap.app": {
    "id": "com.msginfo.messageinfo",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}"
  },

  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },

  "sap.ui5": {
    "flexEnabled": true,

    "dependencies": {
      "minUI5Version": "1.146.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },

    "contentDensities": {
      "compact": true,
      "cozy": true
    },

    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.msginfo.messageinfo.i18n.i18n"
        }
      }
    },

    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },

    "rootView": {
      "viewName": "com.msginfo.messageinfo.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    },

    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlId": "app",
        "controlAggregation": "pages",
        "transition": "slide",
        "async": true,
        "viewType": "XML",
        "viewPath": "com.msginfo.messageinfo.view"
      },
      "routes": [
        {
          "name": "main",
          "pattern": "",
          "target": "mainTarget"
        }
      ],
      "targets": {
        "mainTarget": {
          "type": "View",
          "name": "Main",
          "id": "Main",
          "viewType": "XML"
        }
      }
    }
  }
}