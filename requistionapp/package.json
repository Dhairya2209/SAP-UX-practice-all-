{
  "name": "requisition-app",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@sap/cds": "^9.8.5"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9.8.4",
    "@cap-js/sqlite": "^2.2.0",
    "cds-plugin-ui5": "^0.13.6"
  },
  "cds": {
    "requires": {
      "auth": {
        "kind": "mocked",
        "users": {
          "*": {
            "roles": [
              "authenticated-user",
              "Manager"
            ]
          }
        }
      },
      "db": {
        "kind": "sqlite",
        "impl": "@cap-js/sqlite",
        "credentials": {
          "url": "requisition.db"
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "scripts": {
    "watch-reqcapapp": "cds watch --open demo.reqapp.reqcapapp/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "sapux": [
    "app/reqcapapp"
  ]
}